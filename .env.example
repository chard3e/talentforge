# ========================
# TalentForge Environment Variables
# ========================

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password123

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=talentforge
POSTGRES_PASSWORD=talentforge123
POSTGRES_DB=talentforge

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO (S3 uyumlu)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=talentforge
MINIO_SECRET_KEY=talentforge123
MINIO_BUCKET_NAME=talentforge-cvs

# Uygulama Ayarları
ENV=development
DEBUG=true

# LLM (Ollama yerel geliştirme için)
OLLAMA_BASE_URL=http://host.docker.internal:11434
# Ollama model isimleri
DEFAULT_LLM_MODEL=llama3.1:8b
EMBEDDING_MODEL=bge-m3

# Güvenlik (geliştirme aşamasında)
SECRET_KEY=super-secret-key-change-in-production